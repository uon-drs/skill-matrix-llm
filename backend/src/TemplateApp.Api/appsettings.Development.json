{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },

  "ConnectionStrings": {
    // Update this to point to your local PostgreSQL instance.
    // Format: Host=<host>;Port=5432;Database=<db>;Username=<user>;Password=<pass>
    "DefaultConnection": "Host=localhost;Port=5432;Database=templateapp_dev;Username=postgres;Password=postgres"
  },

  "Keycloak": {
    // Local Keycloak instance
    "AuthServerUrl": "http://localhost:8080",
    // Keycloak realm
    "Realm": "templateapp",
    // Dedicated Keycloak client for the API, used primarily for validating access tokens.
    "Resource": "templateapp-api",
    // Client secret
    "Secret": "your-secret-here",
    // Public Keycloak client that can be used for development and testing purposes
    "PublicClientId": "templateapp-public"
  },

  "OutboundEmail": {
    "Provider": "smtp",
    "SmtpHost": "localhost",
    "SmtpPort": 1025,
    "SmtpSecureSocketEnum": 1,
    "SmtpUsername": "example",
    "SmtpPassword": "example"
  },

  "AllowedOrigins": [
    "http://localhost:3000"
  ]
}
