# ============================================================
# Auth.js
# ============================================================
# URL of this application (no trailing slash). Optional — auto-detected in most environments.
AUTH_URL=http://localhost:3000

# Secret used to sign/encrypt Auth.js JWTs and cookies.
# Generate with: openssl rand -base64 32
AUTH_SECRET=<generate-with-openssl-rand-base64-32>

# ============================================================
# Keycloak
# ============================================================
# The client ID of the Keycloak client created for this frontend
AUTH_KEYCLOAK_ID=templateapp-frontend

# The client secret (leave empty for public/PKCE-only clients)
AUTH_KEYCLOAK_SECRET=<from-keycloak-client-settings>

# Full issuer URL: https://<host>/realms/<realm>
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/templateapp

# ============================================================
# Backend API
# ============================================================
# Base URL of the backend API (used in server components to call the API)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
